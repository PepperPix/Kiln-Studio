<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Bootstrap: local Kiln packages until Kiln.Core / Kiln.Abstractions are published to nuget.org.
      See README.md for instructions. Remove this source once packages are available on nuget.org.
    -->
    <add key="kiln-local" value="/tmp/kiln-localfeed" />
  </packageSources>
</configuration>
