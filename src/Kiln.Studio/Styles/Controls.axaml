<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"
        xmlns:avedit="https://github.com/avaloniaui/avaloniaedit">

    <!-- ==========================================
         Ember Design Language — Control Styles
         ADR-031: Buttons, Lists, Inputs, Splitters
         ========================================== -->

    <!-- ── Button base ── -->
    <Style Selector="Button">
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}" />
        <Setter Property="Background" Value="{StaticResource KilnSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControl}" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceAltBrush}" />
    </Style>

    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="{StaticResource KilnBackgroundBrush}" />
    </Style>

    <Style Selector="Button:disabled">
        <Setter Property="Opacity" Value="0.45" />
    </Style>

    <!-- ── Primary button (Ember orange — main action) ── -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnPrimaryBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.primary:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryHoverBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnPrimaryHoverBrush}" />
    </Style>

    <Style Selector="Button.primary:pressed">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnPrimaryMutedBrush}" />
    </Style>

    <!-- Legacy alias for existing Views using primary-action -->
    <Style Selector="Button.primary-action">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnPrimaryBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.primary-action:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryHoverBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnPrimaryHoverBrush}" />
    </Style>

    <!-- ── Secondary button (Surface + Border) ── -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
    </Style>

    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceAltBrush}" />
    </Style>

    <!-- Checked state for ToggleButton.secondary (Frontmatter/Preview toggles etc.) — without this,
         FluentTheme's default :checked style takes over and paints a jarring accent-blue background
         instead of matching the app's muted dark palette (bug fix, 2026-07-13). -->
    <Style Selector="ToggleButton.secondary:checked">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryMutedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnPrimaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
    </Style>

    <Style Selector="ToggleButton.secondary:checked:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryMutedBrush}" />
    </Style>

    <!-- ── Quiet button (toolbar — no visible border) ── -->
    <Style Selector="Button.quiet">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource TransparentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="Button.quiet:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnBorderBrush}" />
    </Style>

    <!-- ── Gutter toggle (EditorView Frontmatter/Preview collapse handles) ──
         A minimal custom template that deliberately bypasses FluentTheme's built-in ToggleButton
         chrome entirely: overriding the theme's :checked visual via plain Style/local-value Setters
         did not work (that state is painted by an internal template part, not the Background
         property), and these buttons don't need a "checked" highlight anyway — the chevron icon's
         direction already communicates panel state (bug fix, 2026-07-13). -->
    <Style Selector="ToggleButton.gutter-toggle">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_GutterToggleBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource CornerRadiusControl}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.gutter-toggle:pointerover /template/ Border#PART_GutterToggleBorder">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceAltBrush}" />
    </Style>

    <!-- ── CheckBox ── -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── TextBox ── -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControl}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="SelectionBrush" Value="{StaticResource KilnPrimaryMutedBrush}" />
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{StaticResource KilnPrimaryBrush}" />
    </Style>

    <Style Selector="TextBox.monospace">
        <Setter Property="FontFamily" Value="{StaticResource KilnCodeFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeXS}" />
    </Style>

    <!-- Markdown.Avalonia code-render controls: override their default OS-dependent font list
         (the root cause of the Ubuntu CI glyph-typeface crash) with the bundled JetBrains Mono. -->
    <Style Selector="ctxt|CCode">
        <Setter Property="MonospaceFontFamily" Value="{StaticResource KilnCodeFontFamily}" />
    </Style>
    <Style Selector="TextBlock.CodeBlock">
        <Setter Property="FontFamily" Value="{StaticResource KilnCodeFontFamily}" />
    </Style>
    <Style Selector="avedit|TextEditor">
        <Setter Property="FontFamily" Value="{StaticResource KilnCodeFontFamily}" />
    </Style>

    <!-- ── ComboBox ── -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControl}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="Background" Value="{StaticResource KilnSurfaceBrush}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="ComboBoxItem:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceAltBrush}" />
    </Style>

    <!-- ── DatePicker (Frontmatter form) ── -->
    <Style Selector="DatePicker">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControl}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="MinWidth" Value="220" />
    </Style>

    <!-- ── TreeView ── -->
    <Style Selector="TreeView">
        <Setter Property="Background" Value="{StaticResource KilnBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,4" />
    </Style>

    <Style Selector="TreeViewItem">
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="MinHeight" Value="{StaticResource RowHeight}" />
        <Setter Property="Padding" Value="4,2" />
    </Style>

    <Style Selector="TreeViewItem:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceAltBrush}" />
    </Style>

    <Style Selector="TreeViewItem:selected">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
    </Style>

    <Style Selector="TreeViewItem:selected:focus">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryMutedBrush}" />
    </Style>

    <!-- ── ListBox ── -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="{StaticResource KilnBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
        <Setter Property="MinHeight" Value="{StaticResource RowHeight}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceAltBrush}" />
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryMutedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextBrush}" />
    </Style>

    <!-- ── GridSplitter ── -->
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="{StaticResource KilnBorderBrush}" />
    </Style>

    <Style Selector="GridSplitter:pointerover">
        <Setter Property="Background" Value="{StaticResource KilnPrimaryMutedBrush}" />
    </Style>

    <!-- ── ScrollBar (subtler in dark theme) ── -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
    </Style>

    <!-- ── Draft badge ── -->
    <Style Selector="TextBlock.draft-badge">
        <Setter Property="Foreground" Value="{StaticResource KilnWarnBrush}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeXS}" />
        <Setter Property="FontStyle" Value="Italic" />
    </Style>

    <!-- ── Draft entry title (italic) ── -->
    <Style Selector="TextBlock.entry-title.draft">
        <Setter Property="FontStyle" Value="Italic" />
    </Style>

    <!-- ── Taxonomy chip input (ADR-047/PLAN-063) ── -->
    <Style Selector="Border.chip">
        <Setter Property="Background" Value="{StaticResource KilnSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource KilnBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControl}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="0,0,4,4" />
    </Style>

    <Style Selector="Button.chip-remove">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource TransparentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource KilnTextMutedBrush}" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="MinWidth" Value="18" />
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeXS}" />
    </Style>

    <Style Selector="Button.chip-remove:pointerover">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource TransparentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource KilnErrorBrush}" />
    </Style>

</Styles>
