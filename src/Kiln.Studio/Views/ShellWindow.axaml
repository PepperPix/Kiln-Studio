<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kiln.Studio.ViewModels"
        xmlns:views="using:Kiln.Studio.Views"
        xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
        x:Class="Kiln.Studio.Views.ShellWindow"
        x:DataType="vm:ShellViewModel"
        Title="{Binding Title}"
        Width="1200"
        Height="800">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Classes="toolbar-host">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Open" Command="{Binding OpenProjectCommand}" />
                <Button Content="New Page" Command="{Binding NewPageCommand}" />
                <Button Content="Save" Command="{Binding Editor.SaveCommand}" />
                <Button Content="Settings" Command="{Binding OpenSettingsCommand}" />
                <Button Content="Build" Command="{Binding BuildCommand}" Classes="primary-action" />
                <CheckBox Content="Release" IsChecked="{Binding ReleaseBuild}" VerticalAlignment="Center" />
                <Button Content="Preview" Command="{Binding StartFullPreviewCommand}" />
                <Button Content="Stop" Command="{Binding StopFullPreviewCommand}" IsEnabled="{Binding Preview.IsServing}" />
                <Button Content="Deploy">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Set up GitHub Pages" Command="{Binding SetUpGitHubPagesCommand}" />
                            <MenuItem Header="Set up Azure Static Web Apps" Command="{Binding SetUpAzureStaticWebAppsCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Classes="status-host">
            <DockPanel>
                <ProgressBar DockPanel.Dock="Right"
                             Classes="busy-indicator"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsBusy}" />
                <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <!-- Welcome view (no project open) -->
        <views:WelcomeView IsVisible="{Binding !IsProjectOpen}"
                           DataContext="{Binding}" />

        <!-- Three-pane content area (project open) -->
        <Grid IsVisible="{Binding IsProjectOpen}" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="120" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="280" MinWidth="120" />
            </Grid.ColumnDefinitions>

            <!-- Explorer -->
            <TreeView Grid.Column="0"
                      x:Name="ExplorerTree"
                      ItemsSource="{Binding Explorer.Collections}">
                <TreeView.DataTemplates>
                    <TreeDataTemplate DataType="vm:ContentCollectionViewModel"
                                      ItemsSource="{Binding Entries}">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    </TreeDataTemplate>
                    <DataTemplate DataType="vm:ContentEntryViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding Title}" />
                            <TextBlock Text="(draft)" IsVisible="{Binding Draft}"
                                       Foreground="Gray" FontStyle="Italic" />
                        </StackPanel>
                    </DataTemplate>
                </TreeView.DataTemplates>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns" />

            <!-- Editor (middle) -->
            <views:EditorView Grid.Column="2" DataContext="{Binding Editor}" />

            <GridSplitter Grid.Column="3" Width="4" ResizeDirection="Columns" />

            <!-- Preview pane (right) -->
            <DockPanel Grid.Column="4">
                <!-- Serve status strip -->
                <Border DockPanel.Dock="Bottom"
                        IsVisible="{Binding Preview.IsServing}"
                        Classes="preview-status-host"
                        Padding="4,2">
                    <TextBlock Text="{Binding Preview.ServeStatus}"
                               Classes="muted"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <!-- Markdown body preview -->
                <md:MarkdownScrollViewer
                    IsVisible="{Binding Editor.HasDocument}"
                    Markdown="{Binding Editor.Body}" />

                <!-- Placeholder when no document -->
                <TextBlock Text="Preview"
                           IsVisible="{Binding !Editor.HasDocument}"
                           Classes="muted"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           />
            </DockPanel>
        </Grid>

    </DockPanel>

</Window>
