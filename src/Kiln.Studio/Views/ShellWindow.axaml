<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Kiln.Studio.ViewModels"
        xmlns:views="using:Kiln.Studio.Views"
        xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
        x:Class="Kiln.Studio.Views.ShellWindow"
        x:DataType="vm:ShellViewModel"
        Title="{Binding Title}"
        Width="1200"
        Height="800"
        Icon="/Assets/kiln-studio.ico">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Classes="toolbar-host"
                IsVisible="{Binding IsProjectOpen}">
            <StackPanel Orientation="Horizontal" Spacing="4">

                <!-- Project Switcher group -->
                <Button Classes="secondary"
                        Padding="8,6">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft">
                            <StackPanel Spacing="0" MinWidth="220">
                                <!-- Recent projects -->
                                <ItemsControl ItemsSource="{Binding RecentProjects}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RecentProjectViewModel">
                                            <Button Content="{Binding Name}"
                                                    Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).SwitchRecentCommand}"
                                                    CommandParameter="{Binding Path}"
                                                    Classes="quiet"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Padding="8,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Separator Margin="0,4" />
                                <Button Content="Open…"
                                        Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).OpenProjectCommand}"
                                        Classes="quiet"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,6" />
                                <Button Content="New Site…"
                                        Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).NewSiteCommand}"
                                        Classes="quiet"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,6" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding CurrentProjectName}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="▾"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource KilnTextMutedBrush}" />
                    </StackPanel>
                </Button>

                <Button Content="Close"
                        Command="{Binding CloseProjectCommand}"
                        Classes="quiet" />

                <!-- Separator -->
                <Border Width="1"
                        Background="{StaticResource KilnBorderBrush}"
                        Margin="4,4" />

                <!-- Navigation group -->
                <Button Content="New Page"
                        Command="{Binding NewPageCommand}"
                        Classes="secondary" />

                <!-- Separator -->
                <Border Width="1"
                        Background="{StaticResource KilnBorderBrush}"
                        Margin="4,4" />

                <!-- File group -->
                <Button Content="Save"
                        Command="{Binding Editor.SaveCommand}"
                        Classes="secondary" />

                <!-- Separator -->
                <Border Width="1"
                        Background="{StaticResource KilnBorderBrush}"
                        Margin="4,4" />

                <!-- Build group — primary action -->
                <Button Content="Build"
                        Command="{Binding BuildCommand}"
                        Classes="primary" />
                <CheckBox Content="Release"
                          IsChecked="{Binding ReleaseBuild}"
                          VerticalAlignment="Center"
                          Margin="4,0" />

                <!-- Separator -->
                <Border Width="1"
                        Background="{StaticResource KilnBorderBrush}"
                        Margin="4,4" />

                <!-- Preview group -->
                <Button Content="Preview"
                        Command="{Binding StartFullPreviewCommand}"
                        Classes="secondary" />
                <Button Content="Stop"
                        Command="{Binding StopFullPreviewCommand}"
                        IsEnabled="{Binding Preview.IsServing}"
                        Classes="secondary" />

                <!-- Separator -->
                <Border Width="1"
                        Background="{StaticResource KilnBorderBrush}"
                        Margin="4,4" />

                <!-- Deploy group -->
                <Button Content="Deploy"
                        Classes="secondary">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Set up GitHub Pages"
                                      Command="{Binding SetUpGitHubPagesCommand}" />
                            <MenuItem Header="Set up Azure Static Web Apps"
                                      Command="{Binding SetUpAzureStaticWebAppsCommand}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <!-- Separator -->
                <Border Width="1"
                        Background="{StaticResource KilnBorderBrush}"
                        Margin="4,4" />

                <!-- Settings -->
                <Button Content="Settings"
                        Command="{Binding OpenSettingsCommand}"
                        Classes="quiet" />

            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Classes="status-host">
            <DockPanel>
                <ProgressBar DockPanel.Dock="Right"
                             Classes="busy-indicator"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsBusy}" />
                <TextBlock Text="{Binding StatusMessage}"
                           Classes="status-text"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <!-- Welcome view (no project open) -->
        <views:WelcomeView IsVisible="{Binding !IsProjectOpen}"
                           DataContext="{Binding}" />

        <!-- Three-pane content area (project open) -->
        <Grid IsVisible="{Binding IsProjectOpen}" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="120" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="280" MinWidth="120" />
            </Grid.ColumnDefinitions>

            <!-- Explorer -->
            <TreeView Grid.Column="0"
                      x:Name="ExplorerTree"
                      ItemsSource="{Binding Explorer.Collections}">
                <TreeView.DataTemplates>
                    <TreeDataTemplate DataType="vm:ContentCollectionViewModel"
                                      ItemsSource="{Binding Entries}">
                        <TextBlock Text="{Binding Name}"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeXS}" />
                    </TreeDataTemplate>
                    <DataTemplate DataType="vm:ContentEntryViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding Title}" />
                            <TextBlock Text="draft"
                                       IsVisible="{Binding Draft}"
                                       Classes="draft-badge" />
                        </StackPanel>
                    </DataTemplate>
                </TreeView.DataTemplates>
            </TreeView>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

            <!-- Editor (middle) -->
            <views:EditorView Grid.Column="2" DataContext="{Binding Editor}" />

            <GridSplitter Grid.Column="3" ResizeDirection="Columns" />

            <!-- Preview pane (right) -->
            <DockPanel Grid.Column="4">
                <!-- Serve status strip -->
                <Border DockPanel.Dock="Bottom"
                        IsVisible="{Binding Preview.IsServing}"
                        Classes="preview-status-host"
                        Padding="4,2">
                    <TextBlock Text="{Binding Preview.ServeStatus}"
                               Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <!-- Markdown body preview -->
                <md:MarkdownScrollViewer
                    IsVisible="{Binding Editor.HasDocument}"
                    Markdown="{Binding Editor.Body}" />

                <!-- Placeholder when no document -->
                <TextBlock Text="Select a file to preview"
                           IsVisible="{Binding !Editor.HasDocument}"
                           Classes="muted"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Grid>

    </DockPanel>

</Window>
