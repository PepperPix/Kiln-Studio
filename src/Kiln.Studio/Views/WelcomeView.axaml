<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kiln.Studio.ViewModels"
             x:Class="Kiln.Studio.Views.WelcomeView"
             x:DataType="vm:ShellViewModel">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16"
                MaxWidth="400">

        <!-- Heading -->
        <TextBlock Text="Kiln Studio"
                   FontSize="24"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />

        <TextBlock Text="A static site builder — dark, warm, focused."
                   Classes="muted"
                   HorizontalAlignment="Center" />

        <!-- Primary actions -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
            <Button Content="New Site"
                    Command="{Binding NewSiteCommand}"
                    Classes="primary" />
            <Button Content="Open Site"
                    Command="{Binding OpenProjectCommand}"
                    Classes="secondary" />
        </StackPanel>

        <!-- Recent projects -->
        <TextBlock Text="Recent Projects"
                   Classes="section-header"
                   Margin="0,16,0,0" />

        <ItemsControl ItemsSource="{Binding RecentProjects}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:RecentProjectViewModel}">
                    <Button Content="{Binding Name}"
                            Command="{Binding OpenCommand}"
                            Classes="quiet"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="0,1" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>

</UserControl>
