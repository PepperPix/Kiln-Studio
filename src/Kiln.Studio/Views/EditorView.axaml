<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kiln.Studio.ViewModels"
             xmlns:aedit="using:AvaloniaEdit"
             xmlns:controls="using:Kiln.Studio.Controls"
             x:Class="Kiln.Studio.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <Grid>
        <!-- Placeholder when no document -->
        <TextBlock Text="Select a file to edit"
                   IsVisible="{Binding !HasDocument}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Classes="muted" />

        <!-- Editor area when document is loaded -->
        <Grid x:Name="DocumentGrid"
              IsVisible="{Binding HasDocument}"
              RowDefinitions="Auto,Auto,4,Auto,*">

            <!-- Slim, always-visible header: collapses/expands the entire frontmatter panel below
                 to reclaim maximum space for the body editor (in addition to the GridSplitter,
                 which can shrink the panel down to a scrollable sliver — see the ScrollViewer
                 below, which is what actually prevents content from overlapping the body editor
                 when dragged small, unlike the old bare StackPanel rows). -->
            <ToggleButton Grid.Row="0"
                          x:Name="FrontmatterPanelToggle"
                          Classes="secondary"
                          IsChecked="True"
                          Content="▾ Frontmatter"
                          HorizontalAlignment="Left"
                          HorizontalContentAlignment="Left"
                          Margin="{StaticResource PanelMargin}" />

            <!-- Structured frontmatter fields + taxonomies + raw-YAML fallback, all inside one
                 ScrollViewer so the GridSplitter below can freely shrink this row's height without
                 any control overflowing/overlapping the body editor — content clips and a vertical
                 scrollbar appears instead once it no longer fits. -->
            <ScrollViewer Grid.Row="1"
                          x:Name="FrontmatterScrollViewer"
                          IsVisible="{Binding #FrontmatterPanelToggle.IsChecked}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Structured frontmatter fields: title / date / description -->
                    <StackPanel Margin="{StaticResource PanelMargin}">
                        <TextBlock Text="Title" Classes="section-header" Margin="0,0,0,2" />
                        <TextBox Text="{Binding Title}" PlaceholderText="Untitled" />

                        <TextBlock Text="Date" Classes="section-header" Margin="0,4,0,2" />
                        <DatePicker SelectedDate="{Binding Date}" />

                        <TextBlock Text="Description" Classes="section-header" Margin="0,4,0,2" />
                        <TextBox Text="{Binding Description}"
                                 PlaceholderText="A short summary shown in listings and previews"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="52" />
                    </StackPanel>

                    <!-- Structured taxonomy chip inputs (one per taxonomy declared by the item's collection) -->
                    <Border Classes="settings-section" Margin="{StaticResource PanelMargin}">
                        <ItemsControl ItemsSource="{Binding TaxonomyFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TaxonomyFieldViewModel">
                                    <controls:TaxonomyChipInput Label="{Binding Name}"
                                                                 ItemsSource="{Binding Values}"
                                                                 SuggestionsSource="{Binding Suggestions}"
                                                                 Margin="0,0,0,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Raw YAML front matter fallback (advanced) — collapsed by default, still freely
                         editable when expanded; owned keys (title/date/description/taxonomies) are
                         stripped from FrontMatter so they only ever appear in the structured fields above.
                         A plain ToggleButton (not Expander) is used so it picks up the app's existing
                         Button.secondary styling instead of FluentTheme's unstyled default Expander chrome. -->
                    <StackPanel Margin="{StaticResource PanelMargin}">
                        <ToggleButton x:Name="RawFrontMatterToggle"
                                      Classes="secondary"
                                      HorizontalAlignment="Left"
                                      HorizontalContentAlignment="Left"
                                      Content="Raw frontmatter (advanced)" />
                        <Border IsVisible="{Binding #RawFrontMatterToggle.IsChecked}" Margin="0,4,0,0">
                            <TextBox x:Name="FrontMatterBox"
                                     Text="{Binding FrontMatter}"
                                     AcceptsReturn="True"
                                     Height="120"
                                     Classes="monospace"
                                     BorderThickness="0,0,0,1"
                                     CornerRadius="0"
                                     Padding="8,6"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" />
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Row="2"
                          ResizeDirection="Rows"
                          IsVisible="{Binding #FrontmatterPanelToggle.IsChecked}" />

            <!-- Markdown formatting toolbar for the body editor: wraps/prefixes the current
                 selection with Markdown syntax (PLAN-066, ADR-049 Entscheidung 5 — deliberately
                 not a WYSIWYG editor, the body stays plain Markdown text). -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Spacing="4"
                        Margin="{StaticResource PanelMargin}">
                <Button x:Name="BoldButton" Classes="secondary" Content="B" FontWeight="Bold" Click="OnBoldClick" />
                <Button x:Name="ItalicButton" Classes="secondary" Content="I" FontStyle="Italic" Click="OnItalicClick" />
                <Button x:Name="CodeButton" Classes="secondary" Content="Code" FontFamily="Menlo,Consolas,Courier New,monospace" Click="OnCodeClick" />
                <Button x:Name="CodeBlockButton" Classes="secondary" Content="{}{ }" FontFamily="Menlo,Consolas,Courier New,monospace" Click="OnCodeBlockClick" />
                <Button x:Name="LinkButton" Classes="secondary" Content="Link" Click="OnLinkClick" />
                <Button x:Name="HeadingButton" Classes="secondary" Content="H2" Click="OnHeadingClick" />
                <Button x:Name="BulletListButton" Classes="secondary" Content="List" Click="OnBulletListClick" />
                <Button x:Name="NumberedListButton" Classes="secondary" Content="1. List" Click="OnNumberedListClick" />
                <Button x:Name="BlockquoteButton" Classes="secondary" Content="Quote" Click="OnBlockquoteClick" />
            </StackPanel>

            <!-- Body editor — Text synced via code-behind because TextEditor.Text is not a StyledProperty -->
            <aedit:TextEditor Grid.Row="4"
                              x:Name="BodyEditor"
                              FontFamily="Menlo,Consolas,Courier New,monospace"
                              FontSize="{StaticResource FontSizeXS}"
                              ShowLineNumbers="True"
                              WordWrap="True" />

        </Grid>
    </Grid>

</UserControl>

