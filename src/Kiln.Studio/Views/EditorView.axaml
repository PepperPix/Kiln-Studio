<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Kiln.Studio.ViewModels"
             xmlns:aedit="using:AvaloniaEdit"
             xmlns:controls="using:Kiln.Studio.Controls"
             xmlns:md="https://github.com/whistyun/Markdown.Avalonia"
             xmlns:local="using:Kiln.Studio"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:views="using:Kiln.Studio.Views"
             x:Class="Kiln.Studio.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <Grid>
        <!-- Placeholder when no document -->
        <TextBlock Text="Select an item from the content list"
                   IsVisible="{Binding !HasDocument}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Classes="muted" />

        <!-- Editor mode (ADR-056/PLAN-074): breadcrumb back to the content list, then a two-column
             layout — Title+toolbar+body on the left, a unified right panel with Details/Stats/Preview/
             Assets tabs on the right. A single gutter hosts the only splitter/collapse toggle. -->
        <Grid x:Name="RootGrid"
              IsVisible="{Binding HasDocument}"
              RowDefinitions="Auto,*">

            <!-- Breadcrumb -->
            <Button Grid.Row="0"
                    Content="← Content"
                    Classes="quiet"
                    HorizontalAlignment="Left"
                    Margin="{StaticResource PanelMargin}"
                    Command="{Binding $parent[Window].((vm:ShellViewModel)DataContext).BackToContentListCommand}" />

            <Grid Grid.Row="1"
                  x:Name="DocumentGrid"
                  ColumnDefinitions="*,20,320">

                <!-- Left column: title + Markdown toolbar + body editor -->
                <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,*">

                    <!-- Title row with Save button and unsaved indicator -->
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto,Auto"
                          Margin="{StaticResource PanelMargin}">
                        <TextBox Grid.Column="0"
                                 Text="{Binding Title}"
                                 PlaceholderText="Untitled"
                                 FontSize="{StaticResource FontSizeXL}"
                                 FontWeight="SemiBold"
                                 BorderThickness="0"
                                 Background="Transparent" />

                        <TextBlock Grid.Column="1"
                                   Text="●"
                                   VerticalAlignment="Center"
                                   Margin="8,0,4,0"
                                   Classes="muted"
                                   IsVisible="{Binding IsDirty}" />

                        <Button Grid.Column="2"
                                Content="Save"
                                Classes="secondary"
                                Command="{Binding SaveCommand}" />
                    </Grid>

                    <!-- Markdown formatting toolbar for the body editor: wraps/prefixes the current
                         selection with Markdown syntax (PLAN-066, ADR-049 Entscheidung 5 — deliberately
                         not a WYSIWYG editor, the body stays plain Markdown text).
                         Wrapped in a horizontally-scrolling ScrollViewer (bug fix, 2026-07-13): the
                         toolbar buttons are wider than the available column at narrow window sizes,
                         and Avalonia's StackPanel does not clip overflowing content by default. -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="4"
                                    Margin="{StaticResource PanelMargin}">
                            <Button x:Name="BoldButton" Classes="secondary" Content="B" FontWeight="Bold" Click="OnBoldClick" />
                            <Button x:Name="ItalicButton" Classes="secondary" Content="I" FontStyle="Italic" Click="OnItalicClick" />
                            <Button x:Name="CodeButton" Classes="secondary" Content="Code" FontFamily="Menlo,Consolas,Courier New,monospace" Click="OnCodeClick" />
                            <Button x:Name="CodeBlockButton" Classes="secondary" Content="{}{ }" FontFamily="Menlo,Consolas,Courier New,monospace" Click="OnCodeBlockClick" />
                            <Button x:Name="LinkButton" Classes="secondary" Content="Link" Click="OnLinkClick" />
                            <Button x:Name="HeadingButton" Classes="secondary" Content="H2" Click="OnHeadingClick" />
                            <Button x:Name="BulletListButton" Classes="secondary" Content="List" Click="OnBulletListClick" />
                            <Button x:Name="NumberedListButton" Classes="secondary" Content="1. List" Click="OnNumberedListClick" />
                            <Button x:Name="BlockquoteButton" Classes="secondary" Content="Quote" Click="OnBlockquoteClick" />
                            <Button x:Name="AssetButton" Classes="secondary" Content="Asset" Click="OnAssetClick" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Rein informative Rückmeldung nach einem Asset-Pick/-Upload: Maße, Dateigröße,
                         Skalierungs-Hinweis (PLAN-069). Nur für Bilddateien gesetzt; kein Dialog, kein
                         Toast-Framework, kein Auto-Hide-Timer. -->
                    <TextBlock Grid.Row="2"
                               x:Name="AssetFeedbackText"
                               Text="{Binding LastAssetFeedback}"
                               IsVisible="{Binding LastAssetFeedback, Converter={x:Static ObjectConverters.IsNotNull}}"
                               TextWrapping="Wrap"
                               Classes="muted"
                               Margin="{StaticResource PanelMargin}" />

                    <!-- Body editor — Text synced via code-behind because TextEditor.Text is not a StyledProperty -->
                    <aedit:TextEditor Grid.Row="3"
                                      x:Name="BodyEditor"
                                      FontFamily="Menlo,Consolas,Courier New,monospace"
                                      FontSize="{StaticResource FontSizeXS}"
                                      ShowLineNumbers="True"
                                      WordWrap="True" />
                </Grid>

                <!-- Gutter column: single splitter + collapse toggle for the unified right panel.
                     Both must be DIRECT children of DocumentGrid (not wrapped in a nested Grid):
                     Avalonia's GridSplitter resizes the ColumnDefinitions of its immediate parent
                     Grid, so nesting it one level deeper made it resize a single-column wrapper
                     Grid with nothing to resize instead of DocumentGrid's real columns — the
                     splitter looked draggable but silently did nothing (bug found 2026-07-18). -->
                <GridSplitter Grid.Column="1"
                              ResizeDirection="Columns"
                              HorizontalAlignment="Stretch"
                              IsVisible="{Binding IsRightPanelExpanded}" />
                <ToggleButton Grid.Column="1"
                              x:Name="RightPanelToggle"
                              Classes="gutter-toggle"
                              IsChecked="{Binding IsRightPanelExpanded}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Top"
                              Margin="0,4,0,0"
                              ToolTip.Tip="Panel ein-/ausblenden">
                    <materialIcons:MaterialIcon Kind="{Binding IsRightPanelExpanded, Converter={x:Static local:AppConverters.ExpandedToChevron}}"
                                  Width="14"
                                  Height="14" />
                </ToggleButton>

                <!-- Right column: unified panel with Details/Stats/Preview/Assets tabs. -->
                <TabControl Grid.Column="2"
                            x:Name="RightPanelTabControl">

                    <!-- Compact header padding/font: with the panel narrowed to 320px (down from
                         the old 260px Frontmatter-only column, ADR-056/PLAN-074), FluentTheme's
                         default TabItem padding is wide enough that four headers
                         (Details/Stats/Preview/Assets) wrap onto a second line, visually crowding
                         the Details tab's own content underneath. Scoped to this TabControl only. -->
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="FontSize" Value="{StaticResource FontSizeS}" />
                        </Style>
                    </TabControl.Styles>

                    <TabItem Header="Details">
                        <ScrollViewer x:Name="DetailsScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- Structured frontmatter fields: date / description (title lives
                                     in the left column as the page heading — ADR-054). -->
                                <StackPanel Margin="{StaticResource PanelMargin}">
                                    <TextBlock Text="Date" Classes="section-header" Margin="0,0,0,2" />
                                    <DatePicker SelectedDate="{Binding Date}" />

                                    <TextBlock Text="Description" Classes="section-header" Margin="0,4,0,2" />
                                    <TextBox Text="{Binding Description}"
                                             PlaceholderText="A short summary shown in listings and previews"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Height="52" />
                                </StackPanel>

                                <!-- Structured taxonomy chip inputs (one per taxonomy declared by the item's collection) -->
                                <Border Classes="settings-section" Margin="{StaticResource PanelMargin}">
                                    <ItemsControl ItemsSource="{Binding TaxonomyFields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TaxonomyFieldViewModel">
                                                <controls:TaxonomyChipInput Label="{Binding Name}"
                                                                             ItemsSource="{Binding Values}"
                                                                             SuggestionsSource="{Binding Suggestions}"
                                                                             Margin="0,0,0,4" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Raw YAML front matter fallback (advanced) — collapsed by default, still freely
                                     editable when expanded; owned keys (title/date/description/taxonomies) are
                                     stripped from FrontMatter so they only ever appear in the structured fields above.
                                     A plain ToggleButton (not Expander) is used so it picks up the app's existing
                                     Button.secondary styling instead of FluentTheme's unstyled default Expander chrome. -->
                                <StackPanel Margin="{StaticResource PanelMargin}">
                                    <ToggleButton x:Name="RawFrontMatterToggle"
                                                  Classes="secondary"
                                                  HorizontalAlignment="Left"
                                                  HorizontalContentAlignment="Left"
                                                  Content="Raw frontmatter (advanced)" />
                                    <Border IsVisible="{Binding #RawFrontMatterToggle.IsChecked}" Margin="0,4,0,0">
                                        <TextBox x:Name="FrontMatterBox"
                                                 Text="{Binding FrontMatter}"
                                                 AcceptsReturn="True"
                                                 Height="120"
                                                 Classes="monospace"
                                                 BorderThickness="0,0,0,1"
                                                 CornerRadius="0"
                                                 Padding="8,6"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap" />
                                    </Border>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Stats sub-tab (ADR-054/PLAN-072): purely informative word/character/reading-time
                         counts, referenced-asset count, and file-system created/modified dates. -->
                    <TabItem Header="Stats">
                        <StackPanel Margin="{StaticResource PanelMargin}" Spacing="4">
                            <TextBlock Text="Word count" Classes="section-header" Margin="0,0,0,0" />
                            <TextBlock Text="{Binding WordCount}" />

                            <TextBlock Text="Characters" Classes="section-header" />
                            <TextBlock Text="{Binding CharacterCount}" />

                            <TextBlock Text="Reading time" Classes="section-header" />
                            <TextBlock Text="{Binding ReadingTimeMinutes, StringFormat='{}{0} min'}" />

                            <TextBlock Text="Referenced assets" Classes="section-header" />
                            <TextBlock Text="{Binding ReferencedAssetCount}" />

                            <TextBlock Text="Created" Classes="section-header" />
                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />

                            <TextBlock Text="Modified" Classes="section-header" />
                            <TextBlock Text="{Binding ModifiedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                        </StackPanel>
                    </TabItem>

                    <!-- Preview sub-tab: Markdown.Avalonia quick preview (ADR-056). -->
                    <TabItem Header="Preview">
                        <md:MarkdownScrollViewer x:Name="InlinePreview"
                                                 Markdown="{Binding PreviewMarkdown}" />
                    </TabItem>

                    <!-- Assets sub-tab: document-scoped asset browser (ADR-056/PLAN-074). -->
                    <TabItem Header="Assets">
                        <views:AssetBrowserView DataContext="{Binding DocumentAssets}" />
                    </TabItem>

                </TabControl>

            </Grid>
        </Grid>
    </Grid>

</UserControl>


